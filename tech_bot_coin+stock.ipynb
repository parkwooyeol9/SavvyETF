{"cells":[{"cell_type":"code","execution_count":1,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"executionInfo":{"elapsed":11432,"status":"ok","timestamp":1783384042399,"user":{"displayName":"Yore A","userId":"03422702086520480573"},"user_tz":-540},"id":"X2iws8agB1QH","outputId":"b444d47d-685c-4f21-cacc-5df8926da198"},"outputs":[{"output_type":"stream","name":"stdout","text":["Collecting pycoingecko\n","  Downloading pycoingecko-3.2.0-py3-none-any.whl.metadata (16 kB)\n","Requirement already satisfied: requests in /usr/local/lib/python3.12/dist-packages (from pycoingecko) (2.32.4)\n","Requirement already satisfied: charset_normalizer<4,>=2 in /usr/local/lib/python3.12/dist-packages (from requests->pycoingecko) (3.4.7)\n","Requirement already satisfied: idna<4,>=2.5 in /usr/local/lib/python3.12/dist-packages (from requests->pycoingecko) (3.18)\n","Requirement already satisfied: urllib3<3,>=1.21.1 in /usr/local/lib/python3.12/dist-packages (from requests->pycoingecko) (2.5.0)\n","Requirement already satisfied: certifi>=2017.4.17 in /usr/local/lib/python3.12/dist-packages (from requests->pycoingecko) (2026.6.17)\n","Downloading pycoingecko-3.2.0-py3-none-any.whl (10 kB)\n","Installing collected packages: pycoingecko\n","Successfully installed pycoingecko-3.2.0\n"]}],"source":["pip install pycoingecko"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"fdujmhsnV7EQ"},"outputs":[],"source":[]},{"cell_type":"code","execution_count":null,"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"7ZXFs9E6_6tg","outputId":"38d525b3-35b7-45f2-fd82-f58f71fc7d83"},"outputs":[{"metadata":{"tags":null},"name":"stdout","output_type":"stream","text":["Starting Telegram bot...\n","Error in bot loop: ('Connection aborted.', RemoteDisconnected('Remote end closed connection without response'))\n"]}],"source":["import yfinance as yf\n","import pandas as pd\n","import numpy as np\n","from datetime import datetime, timedelta\n","import matplotlib.pyplot as plt\n","import requests\n","import io\n","import base64\n","import time\n","import pandas as pd\n","from pycoingecko import CoinGeckoAPI\n","import matplotlib.pyplot as plt\n","\n","class PortfolioSimulator:\n","    def __init__(self, tickers, start_date=None, end_date=None):\n","        \"\"\"\n","        Initialize portfolio simulator\n","\n","        Parameters:\n","        tickers (list): List of stock tickers\n","        start_date (str): Start date in 'YYYY-MM-DD' format\n","        end_date (str): End date in 'YYYY-MM-DD' format\n","        \"\"\"\n","        self.tickers = tickers\n","        self.start_date = start_date or (datetime.now() - timedelta(days=365)).strftime('%Y-%m-%d')\n","        self.end_date = end_date or datetime.now().strftime('%Y-%m-%d')\n","        self.data = None\n","\n","    def fetch_data(self):\n","        \"\"\"Fetch historical data for all tickers\"\"\"\n","        data_frames = {}\n","        for ticker in self.tickers:\n","            stock = yf.Ticker(ticker)\n","            df = stock.history(start=self.start_date, end=self.end_date)\n","            data_frames[ticker] = df['Close']\n","\n","        # Fetch SPY data for comparison\n","        spy = yf.Ticker('SPY')\n","        spy_df = spy.history(start=self.start_date, end=self.end_date)\n","        data_frames['SPY'] = spy_df['Close']\n","\n","        self.data = pd.DataFrame(data_frames)\n","        return self.data\n","\n","    def calculate_returns(self, weights=None):\n","        \"\"\"\n","        Calculate portfolio returns\n","\n","        Parameters:\n","        weights (list): List of weights for each stock (default: equal weights)\n","\n","        Returns:\n","        dict: Dictionary containing portfolio metrics\n","        \"\"\"\n","        if self.data is None:\n","            self.fetch_data()\n","\n","        if weights is None:\n","            weights = [1/len(self.tickers)] * len(self.tickers)\n","\n","        if len(weights) != len(self.tickers):\n","            raise ValueError(\"Number of weights must match number of tickers\")\n","\n","        # Calculate daily returns\n","        daily_returns = self.data.iloc[:, :-1].pct_change()  # Exclude SPY\n","        spy_returns = self.data['SPY'].pct_change()\n","\n","        # Calculate portfolio returns\n","        portfolio_returns = (daily_returns * weights).sum(axis=1)\n","\n","        # Calculate metrics\n","        annual_return = portfolio_returns.mean() * 252\n","        annual_volatility = portfolio_returns.std() * np.sqrt(252)\n","        sharpe_ratio = annual_return / annual_volatility\n","\n","        return {\n","            'daily_returns': portfolio_returns,\n","            'spy_returns': spy_returns,\n","            'cumulative_returns': (1 + portfolio_returns).cumprod(),\n","            'spy_cumulative_returns': (1 + spy_returns).cumprod(),\n","            'annual_return': annual_return,\n","            'annual_volatility': annual_volatility,\n","            'sharpe_ratio': sharpe_ratio\n","        }\n","\n","    def plot_returns(self):\n","        \"\"\"Generate and return portfolio performance plot\"\"\"\n","        results = self.calculate_returns()\n","\n","        plt.figure(figsize=(10, 6))\n","        plt.plot(results['cumulative_returns'], label='Portfolio')\n","        plt.plot(results['spy_cumulative_returns'], label='SPY')\n","        plt.title('Portfolio Performance vs SPY')\n","        plt.xlabel('Date')\n","        plt.ylabel('Cumulative Returns')\n","        plt.legend()\n","        plt.grid(True)\n","\n","        # Save plot to bytes buffer\n","        buf = io.BytesIO()\n","        plt.savefig(buf, format='png')\n","        buf.seek(0)\n","        plt.close()\n","\n","        return buf\n","\n","def analyze_stock(symbol):\n","    \"\"\"Analyze stock using technical indicators and generate trading signals\"\"\"\n","    # Get historical data\n","    stock = yf.Ticker(symbol)\n","    df = stock.history(period='1y')\n","\n","    # Calculate indicators\n","    df['MA50'] = df['Close'].rolling(window=50).mean()\n","    df['MA200'] = df['Close'].rolling(window=200).mean()\n","    df['EMA12'] = df['Close'].ewm(span=12, adjust=False).mean()\n","    df['EMA26'] = df['Close'].ewm(span=26, adjust=False).mean()\n","    df['MACD'] = df['EMA12'] - df['EMA26']\n","    df['Signal'] = df['MACD'].ewm(span=9, adjust=False).mean()\n","\n","    # Calculate RSI\n","    delta = df['Close'].diff()\n","    gain = delta.clip(lower=0)\n","    loss = (-delta).clip(lower=0)\n","    avg_gain = gain.rolling(window=14, min_periods=14).mean()\n","    avg_loss = loss.rolling(window=14, min_periods=14).mean()\n","    rs = avg_gain / avg_loss\n","    df['RSI'] = 100 - (100 / (1 + rs))\n","\n","    # Generate trading signals\n","    df['Buy_Signal'] = False\n","    df['Sell_Signal'] = False\n","\n","    # MACD crossover signals\n","    df['Buy_Signal'] = ((df['MACD'] > df['Signal']) & (df['MACD'].shift(1) <= df['Signal'].shift(1)))\n","    df['Sell_Signal'] = ((df['MACD'] < df['Signal']) & (df['MACD'].shift(1) >= df['Signal'].shift(1)))\n","\n","    # RSI overbought/oversold signals\n","    df.loc[df['RSI'] < 30, 'Buy_Signal'] |= True\n","    df.loc[df['RSI'] > 70, 'Sell_Signal'] |= True\n","\n","    # Moving Average crossover signals\n","    df.loc[(df['MA50'] > df['MA200']) & (df['MA50'].shift(1) <= df['MA200'].shift(1)), 'Buy_Signal'] |= True\n","    df.loc[(df['MA50'] < df['MA200']) & (df['MA50'].shift(1) >= df['MA200'].shift(1)), 'Sell_Signal'] |= True\n","\n","    # Create plot\n","    fig, (ax1, ax2, ax3) = plt.subplots(3, 1, figsize=(14, 12), sharex=True)\n","\n","    # Price plot with signals\n","    ax1.plot(df.index, df['Close'], label='Price', color='blue')\n","    ax1.plot(df.index, df['MA50'], label='MA50', color='orange')\n","    ax1.plot(df.index, df['MA200'], label='MA200', color='red')\n","\n","    # Plot buy/sell markers\n","    buy_points = df[df['Buy_Signal']]['Close']\n","    sell_points = df[df['Sell_Signal']]['Close']\n","    ax1.scatter(buy_points.index, buy_points, color='green', marker='^', s=100, label='Buy Signal')\n","    ax1.scatter(sell_points.index, sell_points, color='red', marker='v', s=100, label='Sell Signal')\n","\n","    ax1.set_title(f'{symbol.upper()} Price with Trading Signals')\n","    ax1.legend()\n","\n","    # MACD plot with signals\n","    ax2.plot(df.index, df['MACD'], label='MACD', color='green')\n","    ax2.plot(df.index, df['Signal'], label='Signal', color='red')\n","    ax2.bar(df.index, df['MACD'] - df['Signal'], color=['red' if x < 0 else 'green' for x in (df['MACD'] - df['Signal'])], alpha=0.3)\n","    ax2.set_title('MACD with Signal Line Crossovers')\n","    ax2.legend()\n","\n","    # RSI plot with signals\n","    ax3.plot(df.index, df['RSI'], label='RSI', color='purple')\n","    ax3.axhline(30, linestyle='--', color='green', label='Oversold (30)')\n","    ax3.axhline(70, linestyle='--', color='red', label='Overbought (70)')\n","    ax3.fill_between(df.index, 30, df['RSI'], where=(df['RSI'] < 30), color='green', alpha=0.3)\n","    ax3.fill_between(df.index, 70, df['RSI'], where=(df['RSI'] > 70), color='red', alpha=0.3)\n","    ax3.set_title('RSI with Overbought/Oversold Signals')\n","    ax3.legend()\n","\n","    plt.tight_layout()\n","\n","    # Save plot to buffer\n","    buf = io.BytesIO()\n","    plt.savefig(buf, format='png')\n","    buf.seek(0)\n","    plt.close()\n","\n","    return buf\n","\n","def simulate_portfolio(tickers, weights=None, start_date=None, end_date=None):\n","    \"\"\"\n","    Simulate portfolio returns\n","\n","    Parameters:\n","    tickers (list): List of stock tickers\n","    weights (list): List of weights for each stock\n","    start_date (str): Start date in 'YYYY-MM-DD' format\n","    end_date (str): End date in 'YYYY-MM-DD' format\n","\n","    Returns:\n","    tuple: (Portfolio annual return percentage, Portfolio simulator instance)\n","    \"\"\"\n","    simulator = PortfolioSimulator(tickers, start_date, end_date)\n","    results = simulator.calculate_returns(weights)\n","    return results['annual_return'] * 100, simulator  # Return both percentage and simulator instance\n","\n","def analyze_crypto(symbol):\n","    \"\"\"Analyze cryptocurrency using technical indicators and generate trading signals\"\"\"\n","    cg = CoinGeckoAPI()\n","\n","    # Get coin ID\n","    coins = cg.get_coins_list()\n","    symbol_to_id = {coin['symbol'].lower(): coin['id'] for coin in coins}\n","\n","    if symbol.lower() not in symbol_to_id:\n","        raise ValueError(\"Coin not found\")\n","\n","    coin_id = symbol_to_id[symbol.lower()]\n","\n","    # Get historical data\n","    data = cg.get_coin_market_chart_by_id(id=coin_id, vs_currency='usd', days=365)\n","\n","    # Process data\n","    prices = data['prices']\n","    df = pd.DataFrame(prices, columns=['timestamp', 'price'])\n","    df['timestamp'] = pd.to_datetime(df['timestamp'], unit='ms')\n","    df.set_index('timestamp', inplace=True)\n","\n","    # Calculate indicators\n","    df['MA50'] = df['price'].rolling(window=50).mean()\n","    df['MA200'] = df['price'].rolling(window=200).mean()\n","    df['EMA12'] = df['price'].ewm(span=12, adjust=False).mean()\n","    df['EMA26'] = df['price'].ewm(span=26, adjust=False).mean()\n","    df['MACD'] = df['EMA12'] - df['EMA26']\n","    df['Signal'] = df['MACD'].ewm(span=9, adjust=False).mean()\n","\n","    # Calculate RSI\n","    delta = df['price'].diff()\n","    gain = delta.clip(lower=0)\n","    loss = (-delta).clip(lower=0)\n","    avg_gain = gain.rolling(window=14, min_periods=14).mean()\n","    avg_loss = loss.rolling(window=14, min_periods=14).mean()\n","    rs = avg_gain / avg_loss\n","    df['RSI'] = 100 - (100 / (1 + rs))\n","\n","    # Generate trading signals\n","    df['Buy_Signal'] = False\n","    df['Sell_Signal'] = False\n","\n","    # MACD crossover signals\n","    df['Buy_Signal'] = ((df['MACD'] > df['Signal']) & (df['MACD'].shift(1) <= df['Signal'].shift(1)))\n","    df['Sell_Signal'] = ((df['MACD'] < df['Signal']) & (df['MACD'].shift(1) >= df['Signal'].shift(1)))\n","\n","    # RSI overbought/oversold signals\n","    df.loc[df['RSI'] < 30, 'Buy_Signal'] |= True\n","    df.loc[df['RSI'] > 70, 'Sell_Signal'] |= True\n","\n","    # Moving Average crossover signals\n","    df.loc[(df['MA50'] > df['MA200']) & (df['MA50'].shift(1) <= df['MA200'].shift(1)), 'Buy_Signal'] |= True\n","    df.loc[(df['MA50'] < df['MA200']) & (df['MA50'].shift(1) >= df['MA200'].shift(1)), 'Sell_Signal'] |= True\n","\n","    # Create plot\n","    fig, (ax1, ax2, ax3) = plt.subplots(3, 1, figsize=(14, 12), sharex=True)\n","\n","    # Price plot with signals\n","    ax1.plot(df.index, df['price'], label='Price', color='blue')\n","    ax1.plot(df.index, df['MA50'], label='MA50', color='orange')\n","    ax1.plot(df.index, df['MA200'], label='MA200', color='red')\n","\n","    # Plot buy/sell markers\n","    buy_points = df[df['Buy_Signal']]['price']\n","    sell_points = df[df['Sell_Signal']]['price']\n","    ax1.scatter(buy_points.index, buy_points, color='green', marker='^', s=100, label='Buy Signal')\n","    ax1.scatter(sell_points.index, sell_points, color='red', marker='v', s=100, label='Sell Signal')\n","\n","    ax1.set_title(f'{symbol.upper()} Price with Trading Signals')\n","    ax1.legend()\n","\n","    # MACD plot with signals\n","    ax2.plot(df.index, df['MACD'], label='MACD', color='green')\n","    ax2.plot(df.index, df['Signal'], label='Signal', color='red')\n","    ax2.bar(df.index, df['MACD'] - df['Signal'], color=['red' if x < 0 else 'green' for x in (df['MACD'] - df['Signal'])], alpha=0.3)\n","    ax2.set_title('MACD with Signal Line Crossovers')\n","    ax2.legend()\n","\n","    # RSI plot with signals\n","    ax3.plot(df.index, df['RSI'], label='RSI', color='purple')\n","    ax3.axhline(30, linestyle='--', color='green', label='Oversold (30)')\n","    ax3.axhline(70, linestyle='--', color='red', label='Overbought (70)')\n","    ax3.fill_between(df.index, 30, df['RSI'], where=(df['RSI'] < 30), color='green', alpha=0.3)\n","    ax3.fill_between(df.index, 70, df['RSI'], where=(df['RSI'] > 70), color='red', alpha=0.3)\n","    ax3.set_title('RSI with Overbought/Oversold Signals')\n","    ax3.legend()\n","\n","    plt.tight_layout()\n","\n","    # Save plot to buffer\n","    buf = io.BytesIO()\n","    plt.savefig(buf, format='png')\n","    buf.seek(0)\n","    plt.close()\n","\n","    return buf\n","\n","def handle_telegram_message(message):\n","    if message.startswith('/port'):\n","        try:\n","            tickers = message.split()[1:]\n","            if not tickers:\n","                return {'text': \"Please provide stock tickers after /port command (e.g. /portf AAPL MSFT GOOGL)\"}\n","\n","            portfolio_return, simulator = simulate_portfolio(tickers)\n","            responses = []\n","\n","            # Portfolio overview\n","            plot_buffer = simulator.plot_returns()\n","            plot_bytes = base64.b64encode(plot_buffer.getvalue()).decode()\n","            responses.append({\n","                'text': f\"Portfolio Overview:\\nTickers: {', '.join(tickers)}\\nExpected Annual Return: {portfolio_return:.2f}%\",\n","                'photo': plot_bytes\n","            })\n","\n","            # Individual stock analysis\n","            for ticker in tickers:\n","                try:\n","                    plot_buffer = analyze_stock(ticker)\n","                    plot_bytes = base64.b64encode(plot_buffer.getvalue()).decode()\n","                    responses.append({\n","                        'text': f\"Technical Analysis for {ticker.upper()}\",\n","                        'photo': plot_bytes\n","                    })\n","                except Exception as e:\n","                    responses.append({\n","                        'text': f\"Error analyzing {ticker}: {str(e)}\"\n","                    })\n","\n","            return responses\n","\n","        except Exception as e:\n","            return [{'text': f\"Error simulating portfolio: {str(e)}\"}]\n","\n","    elif message.startswith('/coin'):\n","        try:\n","            symbol = message.split()[1]\n","            if not symbol:\n","                return {'text': \"Please provide a coin symbol (e.g. /coin BTC)\"}\n","\n","            plot_buffer = analyze_crypto(symbol)\n","            plot_bytes = base64.b64encode(plot_buffer.getvalue()).decode()\n","\n","            response = {\n","                'text': f\"Technical Analysis for {symbol.upper()}\",\n","                'photo': plot_bytes\n","            }\n","            return [response]\n","\n","        except Exception as e:\n","            return [{'text': f\"Error analyzing cryptocurrency: {str(e)}\"}]\n","\n","    return [{'text': \"Available commands:\\n/portfolio TICKER1 TICKER2 ... - Simulate stock portfolio\\n/coin SYMBOL - Technical analysis for cryptocurrency\"}]\n","\n","def start_telegram_bot():\n","    print(\"Starting Telegram bot...\")\n","    last_update_id = None\n","    telegram_bot_token = \"os.environ.get("TELEGRAM_BOT_TOKEN")\"\n","\n","    while True:\n","        try:\n","            url = f\"https://api.telegram.org/bot{telegram_bot_token}/getUpdates\"\n","            if last_update_id:\n","                url += f\"?offset={last_update_id + 1}\"\n","\n","            response = requests.get(url).json()\n","\n","            if response[\"ok\"]:\n","                updates = response.get(\"result\", [])\n","                for update in updates:\n","                    if \"message\" in update and \"text\" in update[\"message\"]:\n","                        message_text = update[\"message\"][\"text\"]\n","                        chat_id = update[\"message\"][\"chat\"][\"id\"]\n","\n","                        replies = handle_telegram_message(message_text)\n","\n","                        for reply in replies:\n","                            telegram_api_url = f\"https://api.telegram.org/bot{telegram_bot_token}/sendMessage\"\n","                            payload = {\n","                                \"chat_id\": chat_id,\n","                                \"text\": reply['text'],\n","                                \"parse_mode\": \"HTML\"\n","                            }\n","                            requests.post(telegram_api_url, json=payload)\n","\n","                            if 'photo' in reply:\n","                                photo_url = f\"https://api.telegram.org/bot{telegram_bot_token}/sendPhoto\"\n","                                files = {\n","                                    'photo': ('chart.png', base64.b64decode(reply['photo']), 'image/png')\n","                                }\n","                                payload = {\n","                                    \"chat_id\": chat_id,\n","                                    \"caption\": \"Analysis Chart\"\n","                                }\n","                                requests.post(photo_url, data=payload, files=files)\n","\n","                        last_update_id = update[\"update_id\"]\n","\n","            time.sleep(1)\n","\n","        except Exception as e:\n","            print(f\"Error in bot loop: {str(e)}\")\n","            time.sleep(5)\n","\n","if __name__ == \"__main__\":\n","    start_telegram_bot()"]},{"cell_type":"code","execution_count":null,"metadata":{"id":"iR-GHOoZV-_5"},"outputs":[],"source":[]}],"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyNfO9ZIXvYFEcNbEbfmGYXi"},"kernelspec":{"display_name":"Python 3","name":"python3"},"language_info":{"name":"python"}},"nbformat":4,"nbformat_minor":0}