TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
# Optional legacy ETF channel (scheduled /etfcheck, /etf_sector):
# TELEGRAM_CHAT_ID=123456789,-1001234567890
# US scheduled briefs (/summary, /summary_pre, /reddit):
# TELEGRAM_CHAT_ID_US=-1004323836037
# Korea / NXT scheduled briefs (/summary_kor*, /summary_nxt):
# TELEGRAM_CHAT_ID_KOR=-1004386688578
# SavvyESG channel (/esg monitor|accident|overview schedules):
# TELEGRAM_CHAT_ID_ESG=-1004486166524
# Public base URL for summary page (set after deploy, e.g. https://savvyetf-bot.onrender.com)
# SUMMARY_PUBLIC_URL=https://your-app.onrender.com
# Optional separate Korea brief URL (defaults to same host + /summary_kor)
# SUMMARY_KOR_PUBLIC_URL=https://your-app.onrender.com/summary_kor
# KST fixed-time US brief (supports HH:MM, e.g. 7:00)
# SUMMARY_SCHEDULE_HOURS_KST=7:00
# SUMMARY_SCHEDULE_ENABLED=true
# Premarket brief (/summary_pre) before US open — default 21:50 KST
# SUMMARY_PRE_SCHEDULE_ENABLED=true
# SUMMARY_PRE_SCHEDULE_KST=21:50
# SUMMARY_PRE_CATCHUP_MINUTES=60
# Daily /reddit broadcast at 21:00 KST (17/19 disabled)
# REDDIT_SCHEDULE_ENABLED=true
# REDDIT_SCHEDULE_HOURS_KST=21
# REDDIT_SCHEDULE_POLL_SECONDS=60
# Korea intraday brief weekdays at 11:00 KST
# SUMMARY_KOR_INTRA_SCHEDULE_ENABLED=true
# SUMMARY_KOR_INTRA_SCHEDULE_HOURS_KST=11
# Korea EOD brief weekdays at 15:40 KST
# SUMMARY_KOR_SCHEDULE_ENABLED=true
# SUMMARY_KOR_SCHEDULE_KST=15:40
# SUMMARY_NXT_SCHEDULE_ENABLED=true
# SUMMARY_NXT_SCHEDULE_KST=8:30,16:40
# Legacy ETF channel: /etf_sector 08:50 KST (US session days), /etfcheck 15:40 KST (KRX days)
# ETF_SECTOR_SCHEDULE_ENABLED=true
# ETF_SECTOR_SCHEDULE_KST=8:50
# ETFCHECK_SCHEDULE_ENABLED=true
# ETFCHECK_SCHEDULE_KST=15:40
# SavvyESG: /esg monitor 09:00 daily · /esg accident 09:30 · /esg overview 09:45 (KRX days)
# ESG_SCHEDULE_ENABLED=true
# ESG_MONITOR_SCHEDULE_ENABLED=true
# ESG_MONITOR_SCHEDULE_KST=9:00
# ESG_ACCIDENT_SCHEDULE_KST=9:30
# ESG_OVERVIEW_SCHEDULE_KST=9:45
# ESG_SCHEDULE_OVERVIEW_QUERIES=삼성전자,SK하이닉스
# Vercel 4-tab dashboard publish (see webapp/README.md)
# WEB_PUBLISH_URL=https://savvyetf.vercel.app/api/ingest
# WEB_INGEST_SECRET=generate_a_long_random_string
# FRED API key for /macro (free): https://fred.stlouisfed.org/docs/api/api_key.html
# FRED_API_KEY=your_fred_api_key
# SEC EDGAR fair-access User-Agent (required for /macro EDGAR data)
# https://www.sec.gov/os/accessing-edgar-data
# SEC_EDGAR_USER_AGENT=SavvyETF/1.0 (your@email.com)
# or:
# SEC_CONTACT_EMAIL=your@email.com
# Finnhub — /etf_pre /sp_pre /nas_pre, /financial, /macro, /adr history merge, etc.
# https://finnhub.io/
# FINNHUB_API_KEY=your_finnhub_api_key
# FinMind (Taiwan depth for /adr TWSE underlyings): https://finmindtrade.com/
# FINMIND_TOKEN=your_finmind_token
# EODHD (global EOD for /adr history merge): https://eodhd.com/
# EODHD_API_KEY=your_eodhd_api_key
# Open DART (Korean /dart fundamentals): https://opendart.fss.or.kr/
# DART_API_KEY=your_dart_api_key
# Financial Modeling Prep (analyst estimates etc.): https://site.financialmodelingprep.com/register
# FMP_API_KEY=your_fmp_api_key
# Gemini for /aibriefing, /reddit, and /summary AI brief: https://aistudio.google.com/apikey
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.5-flash
# Optional Reddit app credentials for /reddit OAuth JSON (scores/flair). Public RSS works without these.
# https://www.reddit.com/prefs/apps
# REDDIT_CLIENT_ID=your_reddit_client_id
# REDDIT_CLIENT_SECRET=your_reddit_client_secret
# Defer heavy scheduled jobs after boot (Render health check / avoid startup OOM)
# SCHEDULER_STARTUP_GRACE_SECONDS=180
# Defer heavy Yahoo cache warmup to background thread (saves startup RAM)
# BOT_DEFER_CACHE_WARMUP=true
# BOT_STARTUP_CACHE_UNIVERSES=etf
# BOT_DEFERRED_CACHE_UNIVERSES=sp,nas
# On Render Starter: set BOT_STARTUP_CACHE_UNIVERSES= (empty) to skip boot warmup
# Linux allocator tuning for small containers
# MALLOC_ARENA_MAX=2
# MEMORY_DEBUG=true
# SUMMARY_HEAVY_WORK_WAIT_SECONDS=600
