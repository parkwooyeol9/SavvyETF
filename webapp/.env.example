# Copied to Vercel project env (and optionally .env.local for local ingest tests)
WEB_INGEST_SECRET=generate_a_long_random_string

# Preferred durable store: Cloudflare R2 (Hobby Blob replacement)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=savvyetf-briefs
# Optional public CDN base (r2.dev or custom domain, no trailing slash):
# R2_PUBLIC_BASE_URL=https://pub-xxxxx.r2.dev
# Or force media proxy base (defaults to this Vercel deployment):
# BRIEF_MEDIA_BASE_URL=https://savvyetf.vercel.app/api/briefs/media

# Legacy optional — only if you still keep a Vercel Blob store:
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

# Optional override for heatmap proxy (defaults to savvyetf-bot.onrender.com):
# RENDER_BOT_URL=https://savvyetf-bot.onrender.com
